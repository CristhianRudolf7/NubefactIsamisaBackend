# Configuración de Base de Datos SQL Server (Docker)
DATABASE_URL=mssql+pyodbc://sa:YourPassword@localhost:1433/isamisa_db?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# API NubeFact
NUBEFACT_URL=https://api.nubefact.com/api/v1/YOUR_API_ID
NUBEFACT_TOKEN=YOUR_API_TOKEN

# Aplicación
APP_NAME=Sistema de Gestión de Documentos Electrónicos
APP_VERSION=1.0.0
DEBUG=True

# Autenticación JWT
SECRET_KEY=your_secret_key_here_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
